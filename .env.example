# 로컬: 복사 후 `.env.local`로 저장하고 <db_password> 등을 채우세요.

# MONGO_URI 기본 DB는 /math (수학 콘텐츠). 사용자 문서는 별도 DB `user`의 users 컬렉션(MONGO_USER_DB, 기본 user).

# querySrv ECONNREFUSED 오류 시: mongodb+srv 대신 Atlas에서 복사한 mongodb:// 표준 연결 문자열을 MONGO_URI에 넣으세요 (SRV DNS 미사용).

MONGO_URI=mongodb+srv://2xteam:<db_password>@cluster0.byos9f6.mongodb.net/math?retryWrites=true&w=majority&appName=Cluster0
# MONGO_USER_DB=user

# https://platform.openai.com/api-keys — `sk-` 또는 `sk-proj-` 로 시작하는 비밀 키
OPENAI_API_KEY=your_openai_api_key
# 채팅용 모델
# OPENAI_MODEL=gpt-4o-mini
# Vision(이미지 분석)용 모델 — 수학 문제 인식에 gpt-4.1-mini 추천
# OPENAI_VISION_MODEL=gpt-4.1-mini

# 세션 쿠키 공유 도메인. 서브도메인 간 로그인 공유 시 상위 도메인 앞에 점(.)을 붙여 설정.
NEXT_PUBLIC_COOKIE_DOMAIN=.myjane.co.kr

# Cloudflare R2 이미지 스토리지
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=snapnote-uploads
R2_PUBLIC_URL=https://pub-xxxx.r2.dev
